---
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/png" href={`${base}/favicon.png?v=4`} />
    <link rel="apple-touch-icon" href={`${base}/favicon.png?v=4`} />
    <link rel="shortcut icon" type="image/png" href={`${base}/favicon.png?v=4`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
