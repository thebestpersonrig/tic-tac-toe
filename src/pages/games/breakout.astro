---
import GameLayout from '../../layouts/GameLayout.astro';
---
<GameLayout title="Breakout">
  <div class="bk-wrapper">

    <!-- Settings screen -->
    <div class="settings-screen active" id="settings-screen">
      <h1 class="game-title">Breakout</h1>
      <div class="settings-form">
        <label class="field">
          <span>Difficulty</span>
          <select id="difficulty-select">
            <option value="easy">Easy</option>
            <option value="medium" selected>Medium</option>
            <option value="hard">Hard</option>
          </select>
        </label>
      </div>
      <button class="btn-primary" id="start-btn">Start Game</button>
    </div>

    <!-- Game screen -->
    <div class="game-screen" id="game-screen">
      <div class="hud">
        <span class="hud-item">Score: <strong id="score-val">0</strong></span>
        <span class="hud-item">Best: <strong id="best-val">0</strong></span>
        <span class="hud-item" id="lives-val">&#9829;&#9829;&#9829;</span>
        <span class="hud-item">Lvl <strong id="level-val">1</strong>/5</span>
        <span class="hud-item diff-badge" id="diff-badge"></span>
      </div>

      <div class="canvas-wrap">
        <canvas id="bk-canvas" aria-label="Breakout game board"></canvas>
        <div class="overlay" id="overlay" hidden>
          <p id="overlay-msg"></p>
          <button class="btn-secondary" id="overlay-btn">Play Again</button>
        </div>
      </div>

      <div class="controls-row">
        <button class="btn-secondary" id="settings-btn">Settings</button>
      </div>
    </div>

  </div>
</GameLayout>

<style is:global>
  html, body { margin: 0; min-height: 100%; }
  body {
    font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
    background:
      radial-gradient(circle at top left,  rgba(255,255,255,0.12), transparent 26%),
      radial-gradient(circle at bottom right, rgba(255,255,255,0.08), transparent 22%),
      linear-gradient(135deg, #0f0c29, #302b63, #24243e);
    min-height: 100dvh;
    color: #fff;
  }
</style>

<style>
  /* ═══ Layout ═══ */
  .bk-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100dvh;
    padding: 48px 8px 8px;
    box-sizing: border-box;
    gap: 0;
  }

  /* ═══ Settings ═══ */
  .settings-screen {
    display: none; flex-direction: column; align-items: center;
    gap: 20px; width: 100%; max-width: 400px;
  }
  .settings-screen.active { display: flex; }
  .game-title {
    margin: 0; font-size: clamp(1.8rem, 5vw, 2.6rem);
    text-align: center; text-shadow: 0 3px 10px rgba(0,0,0,0.3);
  }
  .settings-form { display: flex; flex-direction: column; gap: 14px; width: 100%; }
  .field {
    display: flex; flex-direction: column; gap: 4px;
    font-size: 0.9rem; color: rgba(255,255,255,0.8);
  }
  select {
    background: rgba(255,255,255,0.12); border: 1px solid rgba(255,255,255,0.25);
    border-radius: 10px; color: #fff; padding: 10px 12px;
    font-size: 1rem; font-family: inherit; cursor: pointer;
    appearance: none; -webkit-appearance: none;
  }
  select option { background: #1a1040; color: #fff; }

  /* ═══ Game screen ═══ */
  .game-screen {
    display: none; flex-direction: column; align-items: center;
    gap: 6px; width: 100%;
  }
  .game-screen.active { display: flex; }

  /* HUD */
  .hud {
    display: flex; flex-wrap: wrap; justify-content: center;
    gap: 2px clamp(8px, 2vw, 16px); align-items: center;
    font-size: clamp(0.68rem, 1.9vw, 0.82rem);
    background: rgba(0,0,0,0.32); padding: 4px 12px; border-radius: 999px;
    max-width: 100%;
  }
  #lives-val { letter-spacing: 2px; color: #ff6b6b; }
  .diff-badge {
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.05em;
    padding: 2px 7px; border-radius: 999px; text-transform: uppercase;
  }
  .diff-badge.easy   { background: rgba(34,197,94,0.2);  color: #4ade80; }
  .diff-badge.medium { background: rgba(245,158,11,0.2); color: #fbbf24; }
  .diff-badge.hard   { background: rgba(239,68,68,0.2);  color: #f87171; }

  /* ═══ Canvas — width-primary, height derived from aspect-ratio ═══ */
  .canvas-wrap {
    position: relative;
    /* width = min of: parent width, height-budget/ratio, desktop max */
    width: min(100%, calc((100dvh - 160px) / 1.4), 500px);
    aspect-ratio: 1 / 1.4;
    border-radius: 14px; overflow: hidden;
    box-shadow: 0 10px 40px rgba(0,0,0,0.55), 0 0 0 1px rgba(255,255,255,0.08);
    flex-shrink: 0;
  }
  #bk-canvas { display: block; width: 100%; height: 100%; }

  /* Overlay */
  .overlay {
    position: absolute; inset: 0; background: rgba(0,0,0,0.72);
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; gap: 16px; border-radius: 14px;
  }
  .overlay[hidden] { display: none; }
  #overlay-msg {
    margin: 0; font-size: clamp(1rem, 4vw, 1.4rem);
    font-weight: 700; text-align: center; padding: 0 16px; white-space: pre-line;
  }

  .controls-row { display: flex; gap: 10px; }

  /* Buttons */
  .btn-primary, .btn-secondary {
    border: none; border-radius: 12px; font-family: inherit; font-weight: 600;
    cursor: pointer; transition: transform 0.15s, background 0.15s;
    -webkit-tap-highlight-color: transparent; min-height: 44px;
  }
  .btn-primary {
    background: #818cf8; color: #1e1b4b;
    font-size: 1.05rem; padding: 12px 28px; width: 100%;
  }
  .btn-primary:hover  { transform: translateY(-2px); background: #6366f1; }
  .btn-secondary {
    background: rgba(255,255,255,0.15); color: #fff;
    font-size: 0.9rem; padding: 9px 20px;
    border: 1px solid rgba(255,255,255,0.2);
  }
  .btn-secondary:hover { background: rgba(255,255,255,0.25); }

  /* Landscape phones */
  @media (orientation: landscape) and (max-height: 500px) {
    .bk-wrapper {
      flex-direction: row; gap: 10px;
      padding: 8px 12px 8px clamp(44px, 9vw, 58px);
    }
    .game-screen { flex-direction: row; align-items: center; gap: 10px; }
    .canvas-wrap {
      /* In landscape override with height-based sizing */
      width: min(calc((100dvh - 24px) / 1.4), 45vw);
    }
    .hud { flex-direction: column; gap: 3px; padding: 8px 10px; border-radius: 14px; }
    .controls-row { flex-direction: column; }
  }
</style>

<script is:inline>
(function () {
  var settingsScreen = document.getElementById('settings-screen');
  var gameScreen     = document.getElementById('game-screen');
  var startBtn       = document.getElementById('start-btn');
  var settingsBtn    = document.getElementById('settings-btn');
  var overlay        = document.getElementById('overlay');
  var overlayMsg     = document.getElementById('overlay-msg');
  var overlayBtn     = document.getElementById('overlay-btn');
  var scoreEl        = document.getElementById('score-val');
  var bestEl         = document.getElementById('best-val');
  var livesEl        = document.getElementById('lives-val');
  var levelEl        = document.getElementById('level-val');
  var diffBadge      = document.getElementById('diff-badge');
  var canvas         = document.getElementById('bk-canvas');
  var ctx            = canvas.getContext('2d');
  var diffSel        = document.getElementById('difficulty-select');

  var MAX_LEVEL = 5;
  var LIVES_MAX = 3;
  var LS_BEST   = 'breakout_best';
  var LS_DIFF   = 'breakout_diff';

  var BRICK_COLORS = ['#ff6b6b','#ffa94d','#ffd43b','#69db7c','#74c0fc','#da77f2'];

  var DIFFICULTIES = {
    easy:   { ballSpeed: 3.8, paddleWFrac: 0.24, rows: 3, cols: 7 },
    medium: { ballSpeed: 5.0, paddleWFrac: 0.18, rows: 4, cols: 9 },
    hard:   { ballSpeed: 6.5, paddleWFrac: 0.13, rows: 5, cols: 11 },
  };

  // Per-level additions on top of selected difficulty
  var LEVEL_MODS = [
    { rowAdd: 0, colAdd: 0, speedMult: 1.00 },
    { rowAdd: 1, colAdd: 1, speedMult: 1.15 },
    { rowAdd: 1, colAdd: 2, speedMult: 1.28 },
    { rowAdd: 2, colAdd: 2, speedMult: 1.42 },
    { rowAdd: 2, colAdd: 3, speedMult: 1.58 },
  ];

  // State
  var W, H, animId, levelTimer, gameRunning;
  var ball, paddle, bricks, score, lives, best, launched;
  var diff, levelCfg, level;
  var keys = { left: false, right: false };

  // Scaled constants (computed in initCanvas)
  var BALL_R, PADDLE_H, PADDLE_SPEED, BRICK_MARGIN, BRICK_TOP_PAD;

  /* ── Canvas init ── */
  function initCanvas() {
    var wrap = canvas.parentElement;
    W = wrap.clientWidth;
    H = wrap.clientHeight;
    canvas.width  = W;
    canvas.height = H;
    BALL_R       = Math.max(5, Math.round(W * 0.021));
    PADDLE_H     = Math.max(8, Math.round(H * 0.018));
    PADDLE_SPEED = Math.max(5, Math.round(W * 0.016));
    BRICK_MARGIN = Math.max(3, Math.round(W * 0.012));
    BRICK_TOP_PAD = Math.max(36, Math.round(H * 0.085));
  }

  /* ── Level config ── */
  function getLevelConfig() {
    var mod = LEVEL_MODS[level - 1];
    return {
      rows:       diff.rows + mod.rowAdd,
      cols:       diff.cols + mod.colAdd,
      ballSpeed:  diff.ballSpeed * mod.speedMult,
      paddleWFrac: diff.paddleWFrac,
    };
  }

  function initLevel() {
    levelCfg = getLevelConfig();
    buildBricks();
    resetBall();
  }

  /* ── Bricks ── */
  function buildBricks() {
    bricks = [];
    var rows = levelCfg.rows;
    var cols = levelCfg.cols;
    var totalGapX = BRICK_MARGIN * (cols + 1);
    var bW = (W - totalGapX) / cols;
    var maxBH = (H * 0.44 - BRICK_TOP_PAD) / rows - BRICK_MARGIN;
    var bH = Math.max(6, Math.min(16, maxBH));

    for (var r = 0; r < rows; r++) {
      // r=0 is top row (most points, purple); r=rows-1 is bottom (fewest, red)
      var t = (rows === 1) ? 0 : (rows - 1 - r) / (rows - 1);
      var cIdx = Math.round(t * (BRICK_COLORS.length - 1));
      var color = BRICK_COLORS[cIdx];
      for (var c = 0; c < cols; c++) {
        var x = BRICK_MARGIN + c * (bW + BRICK_MARGIN);
        var y = BRICK_TOP_PAD + r * (bH + BRICK_MARGIN);
        bricks.push({ x: x, y: y, w: bW, h: bH, color: color, active: true, row: r });
      }
    }
  }

  /* ── Ball / paddle reset ── */
  function resetBall() {
    var pW = W * levelCfg.paddleWFrac;
    var pX = (W - pW) / 2;
    var pY = H - Math.round(H * 0.09);
    paddle   = { x: pX, y: pY, w: pW, h: PADDLE_H };
    ball     = { x: pX + pW / 2, y: pY - BALL_R - 1, vx: 0, vy: 0 };
    launched = false;
  }

  function launch() {
    if (!gameRunning || launched) return;
    launched = true;
    var angle = (Math.random() * 50 - 25) * (Math.PI / 180);
    ball.vx = levelCfg.ballSpeed * Math.sin(angle);
    ball.vy = -levelCfg.ballSpeed * Math.cos(angle);
  }

  /* ── Start / restart ── */
  function startGame() {
    cancelAnimationFrame(animId);
    clearTimeout(levelTimer);
    initCanvas();

    var key = diffSel.value;
    diff = DIFFICULTIES[key];
    localStorage.setItem(LS_DIFF, key);
    diffBadge.textContent = key;
    diffBadge.className   = 'hud-item diff-badge ' + key;

    best = parseInt(localStorage.getItem(LS_BEST) || '0', 10);
    bestEl.textContent  = best;
    score = 0;
    scoreEl.textContent = 0;
    lives = LIVES_MAX;
    updateLivesHUD();
    level = 1;
    updateLevelHUD();

    overlay.hidden = true;
    initLevel();

    gameRunning = true;
    animId = requestAnimationFrame(gameLoop);
  }

  /* ── Game loop ── */
  function gameLoop() {
    if (!gameRunning) return;
    animId = requestAnimationFrame(gameLoop);
    update();
    draw();
  }

  /* ── Update ── */
  function update() {
    applyKeyboard();
    if (!launched) {
      ball.x = paddle.x + paddle.w / 2;
      ball.y = paddle.y - BALL_R - 1;
      return;
    }
    var prevX = ball.x;
    var prevY = ball.y;
    ball.x += ball.vx;
    ball.y += ball.vy;
    wallBounce();
    brickCollisions(prevX, prevY);
    paddleCollision();
    checkFallOff();
    checkWin();
  }

  function applyKeyboard() {
    if (keys.left)  paddle.x -= PADDLE_SPEED;
    if (keys.right) paddle.x += PADDLE_SPEED;
    paddle.x = Math.max(0, Math.min(W - paddle.w, paddle.x));
  }

  /* Ensure ball always has meaningful vertical component */
  function clampMinVy() {
    var spd = Math.sqrt(ball.vx * ball.vx + ball.vy * ball.vy);
    var minVy = spd * 0.30;
    if (Math.abs(ball.vy) < minVy) {
      var sign = ball.vy >= 0 ? 1 : -1;
      ball.vy = sign * minVy;
      var rem = Math.sqrt(Math.max(0, spd * spd - minVy * minVy));
      ball.vx = (ball.vx === 0 ? (Math.random() < 0.5 ? 1 : -1) : Math.sign(ball.vx)) * rem;
    }
  }

  function wallBounce() {
    var hit = false;
    if (ball.x - BALL_R < 0) {
      ball.x = BALL_R; ball.vx = Math.abs(ball.vx); hit = true;
    }
    if (ball.x + BALL_R > W) {
      ball.x = W - BALL_R; ball.vx = -Math.abs(ball.vx); hit = true;
    }
    if (ball.y - BALL_R < 0) {
      ball.y = BALL_R; ball.vy = Math.abs(ball.vy); hit = true;
    }
    if (hit) clampMinVy();
  }

  function brickCollisions(prevX, prevY) {
    for (var i = 0; i < bricks.length; i++) {
      var b = bricks[i];
      if (!b.active) continue;
      if (ball.x + BALL_R < b.x)       continue;
      if (ball.x - BALL_R > b.x + b.w) continue;
      if (ball.y + BALL_R < b.y)       continue;
      if (ball.y - BALL_R > b.y + b.h) continue;

      b.active = false;
      score += (levelCfg.rows - b.row);
      scoreEl.textContent = score;
      if (score > best) {
        best = score;
        bestEl.textContent = best;
        localStorage.setItem(LS_BEST, best);
      }

      // Use prev position to pick correct bounce face
      var fromAbove = prevY + BALL_R <= b.y + 2;
      var fromBelow = prevY - BALL_R >= b.y + b.h - 2;
      if (fromAbove || fromBelow) {
        ball.vy = -ball.vy;
      } else {
        ball.vx = -ball.vx;
      }
      clampMinVy();
      break;
    }
  }

  function paddleCollision() {
    if (ball.vy <= 0) return;
    if (ball.y + BALL_R < paddle.y)            return;
    if (ball.y - BALL_R > paddle.y + paddle.h) return;
    if (ball.x + BALL_R < paddle.x)            return;
    if (ball.x - BALL_R > paddle.x + paddle.w) return;

    ball.y = paddle.y - BALL_R;
    var spd    = Math.sqrt(ball.vx * ball.vx + ball.vy * ball.vy);
    var offset = Math.max(0, Math.min(1, (ball.x - paddle.x) / paddle.w));
    // ±50° max angle from vertical
    var angle  = (-50 + offset * 100) * (Math.PI / 180);
    ball.vx = spd * Math.sin(angle);
    ball.vy = -spd * Math.cos(angle);
    // Guarantee at least 40% of speed is upward
    if (-ball.vy < spd * 0.40) {
      ball.vy = -spd * 0.40;
      ball.vx = Math.sign(ball.vx || 1) * Math.sqrt(Math.max(0, spd * spd - ball.vy * ball.vy));
    }
  }

  function checkFallOff() {
    if (ball.y - BALL_R > H) {
      lives--;
      updateLivesHUD();
      if (lives <= 0) {
        endGame(false);
      } else {
        resetBall();
      }
    }
  }

  function checkWin() {
    for (var i = 0; i < bricks.length; i++) {
      if (bricks[i].active) return;
    }
    if (level < MAX_LEVEL) {
      completeLevel();
    } else {
      endGame(true);
    }
  }

  /* ── Level transition ── */
  function completeLevel() {
    gameRunning = false;
    cancelAnimationFrame(animId);
    drawLevelComplete();
    levelTimer = setTimeout(function () {
      level++;
      updateLevelHUD();
      initLevel();
      gameRunning = true;
      animId = requestAnimationFrame(gameLoop);
    }, 2200);
  }

  function drawLevelComplete() {
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, W, H);
    ctx.fillStyle = 'rgba(8, 6, 24, 0.84)';
    ctx.fillRect(0, 0, W, H);

    ctx.textAlign    = 'center';
    ctx.textBaseline = 'middle';

    ctx.fillStyle = '#ffd43b';
    ctx.font = Math.round(W * 0.13) + 'px sans-serif';
    ctx.fillText('★ ★ ★', W / 2, H * 0.30);

    ctx.font = 'bold ' + Math.round(W * 0.09) + 'px "Segoe UI", sans-serif';
    ctx.fillText('Level ' + level + ' Clear!', W / 2, H * 0.46);

    ctx.fillStyle = 'rgba(255,255,255,0.72)';
    ctx.font = Math.round(W * 0.047) + 'px "Segoe UI", sans-serif';
    ctx.fillText('Level ' + (level + 1) + ' of ' + MAX_LEVEL + ' coming up…', W / 2, H * 0.58);
  }

  /* ── HUD helpers ── */
  function updateLivesHUD() {
    livesEl.textContent = '♥'.repeat(lives) + '♡'.repeat(Math.max(0, LIVES_MAX - lives));
  }
  function updateLevelHUD() { levelEl.textContent = level; }

  /* ── End game ── */
  function endGame(won) {
    gameRunning = false;
    cancelAnimationFrame(animId);
    draw();
    overlayMsg.textContent = won
      ? 'You Beat the Game!\nScore: ' + score
      : 'Game Over\nScore: ' + score;
    overlay.hidden = false;
  }

  /* ── Draw ── */
  function draw() {
    ctx.fillStyle = '#1a1a2e';
    ctx.fillRect(0, 0, W, H);

    for (var i = 0; i < bricks.length; i++) {
      var b = bricks[i];
      if (!b.active) continue;
      ctx.fillStyle = b.color;
      ctx.beginPath();
      ctx.roundRect(b.x, b.y, b.w, b.h, 3);
      ctx.fill();
      ctx.fillStyle = 'rgba(255,255,255,0.22)';
      ctx.fillRect(b.x + 2, b.y + 2, b.w * 0.36, 2);
    }

    var padGrad = ctx.createLinearGradient(paddle.x, 0, paddle.x + paddle.w, 0);
    padGrad.addColorStop(0, '#22d3ee');
    padGrad.addColorStop(1, '#3b82f6');
    ctx.fillStyle = padGrad;
    ctx.beginPath();
    ctx.roundRect(paddle.x, paddle.y, paddle.w, paddle.h, 6);
    ctx.fill();
    ctx.fillStyle = 'rgba(255,255,255,0.28)';
    ctx.fillRect(paddle.x + 3, paddle.y + 2, paddle.w * 0.44, 2);

    ctx.save();
    ctx.shadowColor = 'rgba(255,255,255,0.85)';
    ctx.shadowBlur  = 14;
    ctx.fillStyle   = '#fff';
    ctx.beginPath();
    ctx.arc(ball.x, ball.y, BALL_R, 0, Math.PI * 2);
    ctx.fill();
    ctx.restore();

    if (!launched) {
      ctx.fillStyle    = 'rgba(255,255,255,0.5)';
      ctx.textAlign    = 'center';
      ctx.textBaseline = 'middle';
      ctx.font         = Math.round(W * 0.042) + 'px "Segoe UI", sans-serif';
      ctx.fillText('Tap / Space to launch', W / 2, H * 0.76);
    }
  }

  /* ── Input: keyboard ── */
  document.addEventListener('keydown', function (e) {
    if (!gameScreen.classList.contains('active')) return;
    if (e.key === 'ArrowLeft'  || e.key === 'a' || e.key === 'A') { e.preventDefault(); keys.left  = true; }
    if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') { e.preventDefault(); keys.right = true; }
    if (e.code === 'Space' || e.key === ' ') { e.preventDefault(); launch(); }
  });

  document.addEventListener('keyup', function (e) {
    if (e.key === 'ArrowLeft'  || e.key === 'a' || e.key === 'A') keys.left  = false;
    if (e.key === 'ArrowRight' || e.key === 'd' || e.key === 'D') keys.right = false;
  });

  /* ── Input: touch only (no mouse) ── */
  canvas.addEventListener('touchstart', function (e) {
    e.preventDefault();
    launch();
  }, { passive: false });

  canvas.addEventListener('touchmove', function (e) {
    e.preventDefault();
    if (!gameRunning) return;
    var rect   = canvas.getBoundingClientRect();
    var scaleX = W / rect.width;
    var touchX = (e.touches[0].clientX - rect.left) * scaleX;
    paddle.x = Math.max(0, Math.min(W - paddle.w, touchX - paddle.w / 2));
  }, { passive: false });

  /* ── Screen transitions ── */
  startBtn.addEventListener('click', function () {
    settingsScreen.classList.remove('active');
    gameScreen.classList.add('active');
    startGame();
  });

  settingsBtn.addEventListener('click', function () {
    gameRunning = false;
    cancelAnimationFrame(animId);
    clearTimeout(levelTimer);
    gameScreen.classList.remove('active');
    settingsScreen.classList.add('active');
  });

  overlayBtn.addEventListener('click', startGame);

  /* ── Resize: redraw static state only ── */
  var resizeTimer;
  window.addEventListener('resize', function () {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function () {
      if (gameScreen.classList.contains('active') && !gameRunning) {
        initCanvas();
        draw();
      }
    }, 120);
  });

  /* ── Restore saved difficulty ── */
  var savedDiff = localStorage.getItem(LS_DIFF);
  if (savedDiff && DIFFICULTIES[savedDiff]) diffSel.value = savedDiff;
})();
</script>
